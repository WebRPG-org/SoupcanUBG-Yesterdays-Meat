:231,"indent":0,"parameters":[1,"42 (1)",0,0,330,40,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\n<Tatsuya>¨Kaori...I..¨"]},{"code":235,"indent":0,"parameters":[1]},{"code":225,"indent":0,"parameters":[3,5,60,true]},{"code":102,"indent":0,"parameters":[["¨I love you.¨","“I have to go...”"],1,0,2,1]},{"code":402,"indent":0,"parameters":[0,"¨I love you.¨"]},{"code":231,"indent":1,"parameters":[1,"4",0,0,-80,40,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2]},{"code":401,"indent":1,"parameters":["\\nr<Kaori>¨E-eh?¨"]},{"code":235,"indent":1,"parameters":[1]},{"code":231,"indent":1,"parameters":[1,"19",0,0,330,40,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2]},{"code":401,"indent":1,"parameters":["\\n<Tatsuya>“Yes, I love you, Kaori.”"]},{"code":235,"indent":1,"parameters":[1]},{"code":231,"indent":1,"parameters":[1,"40",0,0,330,40,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2]},{"code":401,"indent":1,"parameters":["\\n<Tatsuya>“I would never take away your freedom...What"]},{"code":401,"indent":1,"parameters":["you did was horrible, but what you went through was also"]},{"code":401,"indent":1,"parameters":["horrible.”"]},{"code":101,"indent":1,"parameters":["",0,1,2]},{"code":401,"indent":1,"parameters":["\\n<Tatsuya>“I read your entire diary. I know how you feel.”"]},{"code":101,"indent":1,"parameters":["",0,1,2]},{"code":401,"indent":1,"parameters":["\\n<Tatsuya>“I know how much you love me. I know everything.”"]},{"code":235,"indent":1,"parameters":[1]},{"code":231,"indent":1,"parameters":[1,"41",0,0,330,40,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2]},{"code":401,"indent":1,"parameters":["\\n<Tatsuya>“I love you. I want to help you. That’s why "]},{"code":401,"indent":1,"parameters":["I said you needed help. Let me help you.”"]},{"code":235,"indent":1,"parameters":[1]},{"code":231,"indent":1,"parameters":[1,"5",0,0,-80,40,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2]},{"code":401,"indent":1,"parameters":["\\nr<Kaori>¨Tatsuya...?¨"]},{"code":235,"indent":1,"parameters":[1]},{"code":231,"indent":1,"parameters":[1,"17",0,0,330,40,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2]},{"code":401,"indent":1,"parameters":["\\n<Tatsuya>“Can I stay with you tonight?”"]},{"code":235,"indent":1,"parameters":[1]},{"code":231,"indent":1,"parameters":[1,"3",0,0,-80,40,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2]},{"code":401,"indent":1,"parameters":["\\nr<Kaori>“Y-Yeah...”"]},{"code":235,"indent":1,"parameters":[1]},{"code":223,"indent":1,"parameters":[[-255,-255,-255,0],400,true]},{"code":236,"indent":1,"parameters":["snow",9,60,true]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\nc<Tatsuya>“It’s been a year since then. Winter wraps "]},{"code":401,"indent":1,"parameters":["around us once again.”"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\nc<Tatsuya>“I had to leave my studies to start working."]},{"code":401,"indent":1,"parameters":["I needed to support Kaori. Luckily, she seems to be starting"]},{"code":401,"indent":1,"parameters":["to heal.”"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\nc<Tatsuya>“I imagine it’s time, along with love, that"]},{"code":401,"indent":1,"parameters":["is slowly healing her.”"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\nc<Tatsuya>“Maybe it’s true, after all...Time has a strange"]},{"code":401,"indent":1,"parameters":["way of healing even the deepest wounds.”"]},{"code":230,"indent":1,"parameters":[200]},{"code":261,"indent":1,"parameters":["Ending A"]},{"code":354,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[1,"“I have to go...”"]},{"code":225,"indent":1,"parameters":[3,5,60,true]},{"code":231,"indent":1,