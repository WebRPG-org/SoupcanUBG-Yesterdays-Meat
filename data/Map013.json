{"id":10,"name":"EV010","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["“It seems that on the left side of the bookshelf there "]},{"code":401,"indent":0,"parameters":["are classic storybooks, although they are all in Spanish.”"]},{"code":231,"indent":0,"parameters":[1,"40",0,0,330,40,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\n<Tatsuya>¨...?¨"]},{"code":235,"indent":0,"parameters":[1]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["“A sheet of paper is sticking out of the bookshelf.”"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["“It seems to be a page from \\c[10]Kaori’s diary\\c[0].”"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\"¿Deseas leerla?\""]},{"code":102,"indent":0,"parameters":[["Sí","No"],1,0,2,1]},{"code":402,"indent":0,"parameters":[0,"Sí"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\nc<Kaori>¡No, no, no, no, no, no, no, no, no, no...!\""]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\nc<Kaori>“What have I done, oh my God, what have I done?!”"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\nc<Kaori>“Mom and I argued again about my studies.”"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\nc<Kaori>“I was sick of her scolding and yelling at me...”"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\nc<Kaori>“I couldn’t stop crying a-a-and”"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\nc<Kaori>“And in that state of agitation and nerves I "]},{"code":401,"indent":1,"parameters":["was in, I couldn’t think of a better idea than to hit her"]},{"code":401,"indent":1,"parameters":["in the head with that damn book.”"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\nc<Kaori>“But not once! I hit her over and over and over"]},{"code":401,"indent":1,"parameters":["and over and over and over and over and over and over and"]},{"code":401,"indent":1,"parameters":["over and over...!!!”"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\nc<Kaori>“Until I left her completely disfigured and deformed!!!”"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\nc<Kaori>“God! Forgive me, Mom!”"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\nc<Kaori>“Dad isn’t home, but he will come tonight.”"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\nc<Kaori>“He will kill me, I know he will kill me...”"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\nc<Kaori>“He hates me.”"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\nc<Kaori>“I have to kill him first.”"]},{"code":213,"indent":1,"parameters":[-1,8,true]},{"code":231,"indent":1,"parameters":[1,"20",0,0,330,40,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2]},{"code":401,"indent":1,"parameters":["\\n<Tatsuya>“Is...Is what I’m reading real?”"]},{"code":235,"indent":1,"parameters":[1]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["“You notice that there is something written on the back"]},{"code":401,"indent":1,"para